APP_NAME="GoTo Reports API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# GoTo Connect OAuth2 Credentials
GOTO_CLIENT_ID=
GOTO_CLIENT_SECRET=
GOTO_REDIRECT_URI=http://localhost:8000/goto/callback
GOTO_ACCESS_TOKEN=
GOTO_REFRESH_TOKEN=
GOTO_ACCOUNT_KEY=

# GoTo API Base URLs
GOTO_AUTH_URL=https://authentication.logmeininc.com
GOTO_API_BASE_URL=https://api.goto.com

# Cache Configuration
CACHE_DRIVER=file

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
